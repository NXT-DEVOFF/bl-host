# Database Configuration
DB_DIALECT=sqlite
DB_STORAGE=./database.sqlite
# Pour MySQL :
# DB_DIALECT=mysql
# DB_NAME=blhost
# DB_USER=root
# DB_PASSWORD=your_password
# DB_HOST=localhost

# Server Configuration
NODE_ENV=development
PORT=5000
API_URL=http://localhost:5000

# Security
JWT_SECRET=your_super_secret_key_change_this_in_production
JWT_EXPIRATION=7d

# CORS Configuration
CORS_ORIGIN=http://localhost:5173

# Logging
LOG_LEVEL=info

# =============================================================================
# Gestion réelle des serveurs de jeu (« BL-Host Wings » via Docker)
# -----------------------------------------------------------------------------
# Laissez vide pour rester en mode démo (start/stop simulés).
# Renseignez ces variables pour piloter un vrai hôte Docker (une VM/LXC sur
# votre Proxmox). Voir le guide PROXMOX-DOCKER.md.
#
# Option A — API Docker distante (recommandé, TLS) :
# DOCKER_HOST=tcp://IP_DE_LA_VM:2376
# DOCKER_TLS_VERIFY=1
# DOCKER_CERT_PATH=/home/blhost/docker-certs   # contient ca.pem, cert.pem, key.pem
#
# Option B — backend exécuté SUR l'hôte Docker (socket local) :
# DOCKER_SOCKET=/var/run/docker.sock
